# ============================================================
# CONFIGURACIÓN DEL SISTEMA TRANSMETRO
# Copia este archivo como .env y ajusta los valores
# ============================================================

# Modo de base de datos: "demo" (SQLite) o "postgres"
DB_MODE=demo

# Puerto del servidor
PORT=3000

# Secreto JWT — cambiar por una cadena larga y aleatoria en producción
JWT_SECRET=transmetro_jwt_secret_2026_cambiar_en_produccion

# Expiración del token (1h normal, 7d con "Recordar credenciales")
JWT_EXPIRES_IN=1h
JWT_REMEMBER_EXPIRES_IN=7d

# Simulador de ocupación aleatoria: "on" o "off"
SIMULADOR=off

# Intervalo del simulador en segundos (solo si SIMULADOR=on)
SIMULADOR_INTERVALO=15

# --- Solo necesario si DB_MODE=postgres ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=transmetro_db
DB_USER=postgres
DB_PASSWORD=tu_contrasena_aqui

# Entorno: development | production
NODE_ENV=development
